gpioInit 25
gpioSetDir 25 1

gpioInit 2
gpioSetDir 2 0
gpioPullUp 2

println 'GPIO Init'

btnVal = 0

led = 0

label loop

gpioGet 2 &btnVal
btnVal = 1 - btnVal

if btnVal == 1

println 'Pressed'

led = 1 - led
gpioPut 25 led
println led

label await

gpioGet 2 &btnVal
btnVal = 1 - btnVal

if btnVal == 1
jump await
endif

println 'Released'

endif

sleepMs 50

jump loop